generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  COACH
  ADMIN
}

enum CoachApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Difficulty {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
  EXPERT
}

enum ProgramLevel {
  ACCESSIBLE_TOUS
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
  EXPERT
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                    String                    @id @default(cuid())
  email                 String                    @unique
  passwordHash          String
  role                  Role
  firstName             String?
  lastName              String?
  avatarUrl             String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  stripeCustomerId      String?
  coachProfile          CoachProfile?
  subscriptions         Subscription[]            @relation("UserSubscriptions")
  sessions              SessionToken[]
  resetTokens           PasswordResetToken[]
  viewedPrograms        ViewedProgram[]
  monthlySelections     MonthlyProgramSelection[]
}

model Category {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  createdAt DateTime       @default(now())
  coaches   CoachProfile[]
}

model CoachProfile {
  id                 String                 @id @default(cuid())
  userId             String                 @unique
  slug               String                 @unique
  approvalStatus     CoachApplicationStatus @default(PENDING)
  reviewedAt         DateTime?
  reviewNotes        String?
  headline           String
  bio                String
  photoUrl           String?
  coverImageUrl      String?
  monthlyPrice       Int
  discipline         String
  categoryId         String?
  category           Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  specialities       String
  skills             String
  experienceYears    Int
  coachedClientsCount Int
  addressLine1       String
  city               String
  postalCode         String
  country            String
  phone              String?
  instagramUrl       String?
  tiktokUrl          String?
  youtubeUrl         String?
  linkedinUrl        String?
  websiteUrl         String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  programs             Program[]
  subscriptions        Subscription[]         @relation("CoachSubscriptions")
  pendingSubscriptions Subscription[]         @relation("PendingCoachSubscriptions")
  programSubmissions   ProgramSubmission[]
}

model Program {
  id                   String          @id @default(cuid())
  coachId              String
  title                String
  description          String
  coverImage           String?
  pdfUrl               String?
  difficulty           Difficulty
  totalDurationMinutes Int
  isPublished          Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  coach                CoachProfile    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  workoutSessions      WorkoutSession[]
  viewedBy             ViewedProgram[]
  monthlySelections    MonthlyProgramSelection[]
}

model WorkoutSession {
  id              String          @id @default(cuid())
  programId       String
  title           String
  description     String
  durationMinutes Int
  difficulty      Difficulty
  videoUrl        String?
  order           Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  program         Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  exerciseBlocks  ExerciseBlock[]

  @@unique([programId, order])
}

model ExerciseBlock {
  id          String          @id @default(cuid())
  sessionId   String
  name        String
  sets        Int
  reps        String
  restSeconds Int
  notes       String?
  videoUrl    String?
  order       Int
  session     WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, order])
}

model Subscription {
  id                   String        @id @default(cuid())
  subscriberId         String        @unique
  coachId              String?       // nullable — platform-level plans don't require a specific coach
  plan                 String        @default("ESSENTIELLE")
  pendingCoachId       String?
  stripeSubscriptionId String?       @unique
  status               String        @default("active")
  startedAt            DateTime      @default(now())
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean       @default(false)
  commitmentEndDate    DateTime?     // non-null for plans with a minimum commitment period
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  subscriber    User          @relation("UserSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)
  coach         CoachProfile? @relation("CoachSubscriptions", fields: [coachId], references: [id], onDelete: SetNull)
  pendingCoach  CoachProfile? @relation("PendingCoachSubscriptions", fields: [pendingCoachId], references: [id], onDelete: SetNull)
}

model SessionToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ViewedProgram {
  id           String   @id @default(cuid())
  userId        String
  programId     String
  lastViewedAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
}

model MonthlyProgramSelection {
  id        String   @id @default(cuid())
  userId    String
  programId String
  month     Int
  year      Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId, month, year])
}

model ProgramSubmission {
  id                String           @id @default(cuid())
  coachId           String
  title             String
  description       String
  coverImageUrl     String?
  level             ProgramLevel
  durationMonths    Int
  sessionsPerWeek   Int
  avgSessionMinutes Int
  equipment         String           // JSON array of string values
  equipmentFreeText String?
  status            SubmissionStatus @default(PENDING)
  adminNotes        String?
  reviewedAt        DateTime?
  linkedProgramId   String?          // set when approved and a Program is created
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  coach             CoachProfile     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  pdfs              SubmissionPdf[]
}

model SubmissionPdf {
  id           String            @id @default(cuid())
  submissionId String
  monthNumber  Int               // 1 = mois 1, 2 = mois 2, etc.
  label        String?           // ex: "Mois 1 – Fondamentaux"
  pdfUrl       String
  createdAt    DateTime          @default(now())
  submission   ProgramSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, monthNumber])
}
